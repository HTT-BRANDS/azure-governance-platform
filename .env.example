# =============================================================================
# AZURE GOVERNANCE PLATFORM - COMPLETE ENVIRONMENT CONFIGURATION REFERENCE
# =============================================================================
# Copy this file to .env and fill in your values
# 
# SENSITIVE VARIABLES (marked with 🔒) - Use Key Vault references in production:
#   @Microsoft.KeyVault(SecretUri=https://{vault}.vault.azure.net/secrets/{secret})
#
# GENERATION COMMANDS:
#   JWT Secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   API Key:    openssl rand -hex 32
#
# =============================================================================

# =============================================================================
# SECTION 1: APPLICATION CORE SETTINGS
# =============================================================================

# Environment mode: development | staging | production
# CRITICAL: production requires explicit JWT_SECRET_KEY and no DEBUG mode
ENVIRONMENT=development

# Debug mode - enables detailed error pages and auto-reload
# NEVER set to true in production - security risk
DEBUG=false

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Application name displayed in UI and notifications
APP_NAME=Azure Governance Platform

# Server binding configuration
HOST=0.0.0.0
PORT=8000

# =============================================================================
# SECTION 2: SECURITY & AUTHENTICATION 🔒
# =============================================================================

# JWT Secret Key for token signing
# REQUIRED in production - must be explicitly set, not auto-generated
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# JWT token expiration times
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT algorithm
JWT_ALGORITHM=HS256

# Admin emails for role escalation (comma-separated)
# These users get admin privileges automatically on login
ADMIN_EMAILS=

# Azure AD / Entra ID OAuth2 Configuration (for user login)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=  # 🔒 Use Key Vault reference in production
AZURE_AD_AUTHORITY=https://login.microsoftonline.com/common

# OAuth2 scopes for authentication
OAUTH2_SCOPES=openid,profile,email,User.Read

# Allowed OAuth2 redirect URIs (comma-separated, no wildcards)
# Must include your deployment URLs + /login and /auth/callback paths
ALLOWED_REDIRECT_URIS=http://localhost:8000/login,http://localhost:8000/auth/callback

# =============================================================================
# SECTION 3: DATABASE CONFIGURATION
# =============================================================================

# Database connection URL
# SQLite (default for dev): sqlite:///./data/governance.db
# Azure SQL (production): mssql+pyodbc://username:password@server.database.windows.net/db?driver=ODBC+Driver+18+for+SQL+Server
DATABASE_URL=sqlite:///./data/governance.db

# Connection pool settings (for Azure SQL)
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30

# Query performance monitoring
SLOW_QUERY_THRESHOLD_MS=500.0
ENABLE_QUERY_LOGGING=false

# =============================================================================
# SECTION 4: AZURE SERVICE PRINCIPAL AUTHENTICATION 🔒
# =============================================================================
# Primary tenant credentials for backend Azure API calls

# Managing tenant ID (typically the HTT/primary tenant)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=  # 🔒 Use Key Vault reference in production

# =============================================================================
# SECTION 5: OIDC WORKLOAD IDENTITY FEDERATION (Recommended for Production)
# =============================================================================
# Replaces AZURE_CLIENT_SECRET - zero secrets stored in configuration

# Enable OIDC federation instead of client secrets
USE_OIDC_FEDERATION=false

# Client ID of user-assigned managed identity (leave empty for system-assigned)
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# Allow DefaultAzureCredential fallback for local development
# NEVER set to true in production
OIDC_ALLOW_DEV_FALLBACK=true

# =============================================================================
# SECTION 6: MULTI-TENANT AUTHENTICATION PHASES
# =============================================================================

# Phase B: Single multi-tenant app for all tenants (reduces secrets from 5 to 1)
USE_MULTI_TENANT_APP=false
AZURE_MULTI_TENANT_APP_ID=
AZURE_MULTI_TENANT_CLIENT_SECRET=  # 🔒 Use Key Vault reference in production

# Phase C: Zero-secrets UAMI authentication (most secure option)
USE_UAMI_AUTH=false
UAMI_CLIENT_ID=
UAMI_PRINCIPAL_ID=
FEDERATED_IDENTITY_CREDENTIAL_ID=github-actions-federation

# =============================================================================
# SECTION 7: AZURE KEY VAULT 🔒
# =============================================================================

# Key Vault URL for storing tenant credentials
# Format: https://{vault-name}.vault.azure.net/
KEY_VAULT_URL=

# =============================================================================
# SECTION 8: AZURE LIGHTHOUSE CONFIGURATION
# =============================================================================

# Enable self-service onboarding via Azure Lighthouse
LIGHTHOUSE_ENABLED=true

# Object ID of the Managed Identity for Lighthouse delegation
MANAGED_IDENTITY_OBJECT_ID=

# =============================================================================
# SECTION 9: MANAGED TENANTS
# =============================================================================

# Comma-separated list of tenant IDs to manage
# Leave empty if using Azure Lighthouse for onboarding
MANAGED_TENANT_IDS=

# =============================================================================
# SECTION 10: RIVERSIDE TENANT CONFIGURATION
# =============================================================================

# Enable Riverside compliance tracking features
RIVERSIDE_COMPLIANCE_ENABLED=true

# Riverside Tenant IDs (comma-separated)
RIVERSIDE_TENANT_IDS=tenant-id-1,tenant-id-2,tenant-id-3,tenant-id-4,tenant-id-5

# HTT (Head-To-Toe) Tenant
RIVERSIDE_HTT_TENANT_ID=
RIVERSIDE_HTT_APP_ID=
RIVERSIDE_HTT_CLIENT_SECRET=  # 🔒 Use Key Vault reference in production
RIVERSIDE_HTT_SECRET_REF=htt-client-secret

# BCC (Bishops Cuts/Color) Tenant
RIVERSIDE_BCC_TENANT_ID=
RIVERSIDE_BCC_APP_ID=
RIVERSIDE_BCC_CLIENT_SECRET=  # 🔒 Use Key Vault reference in production
RIVERSIDE_BCC_SECRET_REF=bcc-client-secret

# FN (Frenchies Nails) Tenant
RIVERSIDE_FN_TENANT_ID=
RIVERSIDE_FN_APP_ID=
RIVERSIDE_FN_CLIENT_SECRET=  # 🔒 Use Key Vault reference in production
RIVERSIDE_FN_SECRET_REF=fn-client-secret

# TLL (The Lash Lounge) Tenant
RIVERSIDE_TLL_TENANT_ID=
RIVERSIDE_TLL_APP_ID=
RIVERSIDE_TLL_CLIENT_SECRET=  # 🔒 Use Key Vault reference in production
RIVERSIDE_TLL_SECRET_REF=tll-client-secret

# DCE (Delta Crown Extensions) Tenant
RIVERSIDE_DCE_TENANT_ID=
RIVERSIDE_DCE_APP_ID=
RIVERSIDE_DCE_CLIENT_SECRET=  # 🔒 Use Key Vault reference in production (or use OIDC)
RIVERSIDE_DCE_SECRET_REF=dce-client-secret

# =============================================================================
# SECTION 11: SYNC SCHEDULER CONFIGURATION
# =============================================================================

# How often to sync cost data (in hours)
COST_SYNC_INTERVAL_HOURS=24

# How often to sync compliance data (in hours)
COMPLIANCE_SYNC_INTERVAL_HOURS=4

# How often to sync resource inventory (in hours)
RESOURCE_SYNC_INTERVAL_HOURS=1

# How often to sync identity data (in hours)
IDENTITY_SYNC_INTERVAL_HOURS=24

# Riverside-specific sync interval (in hours)
RIVERSIDE_SYNC_INTERVAL_HOURS=4

# Sync performance settings
BULK_BATCH_SIZE=1000
SYNC_CHUNK_SIZE=1000
ENABLE_PARALLEL_SYNC=true
MAX_PARALLEL_TENANTS=5

# =============================================================================
# SECTION 12: CACHING CONFIGURATION
# =============================================================================

# Enable caching layer
CACHE_ENABLED=true

# Redis URL for distributed caching (optional, uses memory cache if not set)
# Format: redis://username:password@host:port/0
REDIS_URL=

# Default cache TTL (seconds)
CACHE_DEFAULT_TTL_SECONDS=300

# Maximum cache TTL (seconds)
CACHE_MAX_TTL_SECONDS=86400

# Data-type specific TTLs (seconds)
CACHE_TTL_COST_SUMMARY=3600
CACHE_TTL_COMPLIANCE_SUMMARY=1800
CACHE_TTL_RESOURCE_INVENTORY=900
CACHE_TTL_IDENTITY_SUMMARY=3600
CACHE_TTL_RIVERSIDE_SUMMARY=900

# =============================================================================
# SECTION 13: ALERTING & NOTIFICATIONS
# =============================================================================

# Microsoft Teams webhook URL for alerts
TEAMS_WEBHOOK_URL=  # 🔒 Use Key Vault reference in production

# Cost anomaly detection threshold (percentage increase to trigger alert)
COST_ANOMALY_THRESHOLD_PERCENT=20.0

# Compliance score drop threshold (percentage drop to trigger alert)
COMPLIANCE_ALERT_THRESHOLD_PERCENT=5.0

# Notification settings
NOTIFICATION_ENABLED=false
NOTIFICATION_MIN_SEVERITY=warning
NOTIFICATION_COOLDOWN_MINUTES=30

# =============================================================================
# SECTION 14: DMARC/DKIM MONITORING
# =============================================================================

# Enable DMARC/DKIM monitoring
DMARC_DKIM_ENABLED=true

# Sync intervals (in minutes)
DMARC_SYNC_INTERVAL_MINUTES=60
DKIM_SYNC_INTERVAL_MINUTES=60

# Alert thresholds (percentage)
DMARC_FAILURE_THRESHOLD_PERCENT=5.0
DKIM_FAILURE_THRESHOLD_PERCENT=5.0

# Data retention (days)
DMARC_DATA_RETENTION_DAYS=90

# =============================================================================
# SECTION 15: RIVERSIDE COMPLIANCE SETTINGS
# =============================================================================

# Riverside compliance deadline date (YYYY-MM-DD)
RIVERSIDE_DEADLINE_DATE=2026-07-08

# Target MFA coverage percentage
RIVERSIDE_MFA_TARGET=100

# Target maturity score (out of 5.0)
RIVERSIDE_MATURITY_TARGET=3.0

# Financial risk amount in USD (for display purposes)
RIVERSIDE_FINANCIAL_RISK=4000000

# Number of users across all Riverside tenants
RIVERSIDE_TOTAL_USERS=1992

# Number of admin accounts to track
RIVERSIDE_ADMIN_ACCOUNTS=39

# Threat Beta score baseline (if available from Cybeta)
RIVERSIDE_THREAT_BETA_BASELINE=1.0

# Upload directory for compliance evidence files
RIVERSIDE_EVIDENCE_PATH=./data/riverside/evidence

# Tenant-specific MFA targets (comma-separated: tenant_code=target)
# Example: HTT=100,BCC=100,FN=100,TLL=100
RIVERSIDE_TENANT_MFA_TARGETS=

# =============================================================================
# SECTION 16: CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS (comma-separated)
# NO WILDCARDS (*) ALLOWED IN PRODUCTION
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Allowed HTTP methods
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH

# Allowed headers
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,X-Requested-With

# Allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# SECTION 17: RATE LIMITING
# =============================================================================

# Default rate limit (requests per minute)
RATE_LIMIT_DEFAULT=100

# =============================================================================
# SECTION 18: PERFORMANCE & MONITORING
# =============================================================================

# OpenTelemetry tracing
ENABLE_TRACING=false
OTEL_EXPORTER_ENDPOINT=
OTEL_EXPORTER_HEADERS=

# Application Insights (automatically detected in Azure)
# APPLICATIONINSIGHTS_CONNECTION_STRING=  # Set automatically by Azure App Service

# =============================================================================
# SECTION 19: AZURE INFRASTRUCTURE (Auto-detected in Azure)
# =============================================================================

# Azure region (auto-detected)
# AZURE_REGION=

# Azure subscription ID (auto-detected)
# AZURE_SUBSCRIPTION_ID=

# Azure resource group (auto-detected)
# AZURE_RESOURCE_GROUP=

# Azure App Service hostname (set automatically by Azure)
# WEBSITE_HOSTNAME=

# Azure App Service site name (set automatically by Azure)
# WEBSITE_SITE_NAME=

# Managed Identity Object ID (set automatically when using managed identity)
# AZURE_MANAGED_IDENTITY_OBJECT_ID=

# =============================================================================
# SECTION 20: DEVELOPMENT & DEBUGGING
# =============================================================================

# Enable SQL query logging (very verbose)
# SQL_ECHO=false

# Enable API request logging
# API_LOG_REQUESTS=true

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before deploying to production, verify:
#
# [ ] ENVIRONMENT=production is explicitly set
# [ ] DEBUG=false is explicitly set
# [ ] JWT_SECRET_KEY is explicitly set (not auto-generated)
# [ ] All 🔒 sensitive values use Key Vault references
# [ ] CORS_ORIGINS contains only production domains (no localhost)
# [ ] ALLOWED_REDIRECT_URIS contains only production URLs
# [ ] OIDC_ALLOW_DEV_FALLBACK=false
# [ ] USE_OIDC_FEDERATION=true (recommended) OR secrets use Key Vault
# [ ] LOG_LEVEL is set appropriately (INFO or WARNING)
# [ ] Database is Azure SQL (not SQLite)
# [ ] Redis cache is configured for production
# [ ] Application Insights is enabled
# [ ] Rate limiting is configured appropriately
#
# =============================================================================
