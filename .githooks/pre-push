#!/bin/sh
# =============================================================================
# pre-push hook: Run tests before pushing
# =============================================================================
# Runs the test suite before allowing push to remote.
# Can be bypassed with: git push --no-verify
#
# Environment variables:
#   SKIP_PRE_PUSH_TESTS=1 - Skip tests (use with caution!)
#   PRE_PUSH_QUICK=1      - Run only quick unit tests
# =============================================================================

set -e

# Allow skipping with environment variable
if [ "$SKIP_PRE_PUSH_TESTS" = "1" ]; then
    echo "⚠️  Skipping pre-push tests (SKIP_PRE_PUSH_TESTS=1)"
    exit 0
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "${YELLOW}▶ Running pre-push tests...${NC}"
echo ""

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Check if uv is available
if ! command -v uv &> /dev/null; then
    echo "${RED}❌ uv not found. Please install uv: https://docs.astral.sh/uv/${NC}"
    exit 1
fi

# Determine test scope
if [ "$PRE_PUSH_QUICK" = "1" ]; then
    echo "${YELLOW}⚡ Quick mode: Running only unit tests${NC}"
    TEST_CMD="uv run pytest tests/unit/ -q --tb=line"
else
    echo "${YELLOW}Running unit and integration tests...${NC}"
    TEST_CMD="uv run pytest tests/unit/ tests/integration/ -q --tb=short"
fi

# Run ruff check first (fast)
echo "${YELLOW}▶ Running lint checks...${NC}"
if ! uv run ruff check . --quiet; then
    echo "${RED}❌ Lint check failed!${NC}"
    echo "   Run: uv run ruff check . --fix"
    exit 1
fi
echo "${GREEN}✓ Lint checks passed${NC}"
echo ""

# Run ruff format check
echo "${YELLOW}▶ Running format check...${NC}"
if ! uv run ruff format --check . --quiet; then
    echo "${RED}❌ Format check failed!${NC}"
    echo "   Run: uv run ruff format ."
    exit 1
fi
echo "${GREEN}✓ Format checks passed${NC}"
echo ""

# Run mypy type check (optional, can be slow)
if [ "$PRE_PUSH_QUICK" != "1" ]; then
    echo "${YELLOW}▶ Running type checks...${NC}"
    if ! uv run mypy app/ --quiet 2>/dev/null; then
        echo "${YELLOW}⚠️  Type check warnings (non-blocking)${NC}"
    else
        echo "${GREEN}✓ Type checks passed${NC}"
    fi
    echo ""
fi

# Run tests
echo "${YELLOW}▶ Running tests...${NC}"
if ! $TEST_CMD; then
    echo ""
    echo "${RED}❌ Tests failed!${NC}"
    echo ""
    echo "To bypass (NOT RECOMMENDED):"
    echo "  git push --no-verify"
    echo ""
    echo "To run quick tests only:"
    echo "  PRE_PUSH_QUICK=1 git push"
    echo ""
    exit 1
fi

echo ""
echo "${GREEN}✅ All pre-push checks passed!${NC}"
echo ""
exit 0
